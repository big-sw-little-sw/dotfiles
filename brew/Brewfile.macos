# ============================================================
# macOS only - Taps
# ============================================================
tap "homebrew/cask-fonts"
tap "d12frosted/emacs-plus"

# ============================================================
# macOS only (Emacs)
# ============================================================

# Emacs pre-requisites
brew "ripgrep"
brew "coreutils"
brew "fd"

# for compiling vterm, etc.
brew "libtool" 
brew "libvterm"

# ============================================================
# macOS only - Casks
# ============================================================
cask "font-jetbrains-mono-nerd-font"
cask "d12frosted/emacs-plus/emacs-plus-app"

# ============================================================
# macOS only - Casks (Applications)
# ============================================================
cask "claude-code"
cask "ghostty"
cask "kitty"
cask "zed"

# Symbols Nerd Font (Symbols only)
cask "font-symbols-only-nerd-font"
