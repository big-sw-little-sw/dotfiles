# Identity is machine-local — create ~/.gitconfig.local with [user] name/email.
# That file is never committed to the dotfiles repo.
[include]
    path = ~/.gitconfig.local

[core]
    editor     = nvim
    autocrlf   = input
    pager      = delta

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate    = true
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
